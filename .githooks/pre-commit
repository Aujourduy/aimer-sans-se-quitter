#!/usr/bin/env bash
# Hook pre-commit versionné. Activer une fois par machine :
#   git config core.hooksPath .githooks
#
# Régénère la section « Outils » du README depuis package.json, et re-stage
# le README s'il a changé (pour que la MAJ entre dans le même commit).

set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Ne régénérer que si les sources de la liste d'outils sont dans le commit.
if git diff --cached --name-only | grep -qE '^(package\.json|scripts/.*\.mjs)$'; then
  node scripts/generer-outils-readme.mjs
  if ! git diff --quiet -- README.md; then
    git add README.md
    echo "pre-commit : README (section Outils) mis à jour et re-stagé."
  fi
fi

# Garde-fou « README pour les sessions suivantes » : si le commit modifie la
# MÉCANIQUE du projet (schéma des textes, outil de relecture, hooks, scripts,
# config Astro) sans toucher au README, avertir — sans bloquer. Le README est la
# mémoire longue : un changement de mécanique non documenté se perd d'une session
# à l'autre. Le hook ne juge pas le contenu (rôle de l'auteur / de Claude), il
# signale seulement l'oubli probable.
STAGED="$(git diff --cached --name-only)"
if echo "$STAGED" | grep -qE '^(src/content\.config\.ts|scripts/.*\.(mjs|sh)|\.githooks/|astro\.config\.mjs|package\.json)$' \
   && ! echo "$STAGED" | grep -qE '^README\.md$'; then
  echo "⚠  pre-commit : ce commit change la mécanique du projet mais ne touche pas README.md."
  echo "   Si un futur toi (ou Claude) doit connaître ce changement, ajoute une note au README."
  echo "   (Avertissement seulement — le commit continue.)"
fi

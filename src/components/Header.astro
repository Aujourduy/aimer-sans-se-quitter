---
import { url } from '../lib/url';

interface Props {
  // Sur l'accueil, le faux-titre porte la marque : on masque le wordmark.
  wordmark?: boolean;
}
const { wordmark = true } = Astro.props;

const nav = [
  { label: 'Écrits', href: '/textes' },
  { label: 'Livres', href: '/livres' },
  { label: 'À propos', href: '/a-propos' },
  { label: 'Accompagnement', href: '/accompagnement' },
];

// Chemin courant (sans le base) pour marquer le lien actif.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const current = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
---

<header class="site-header" data-dbg="entete">
  <div class={`header-inner${wordmark ? '' : ' sans-marque'}`}>
    {
      wordmark && (
        <a class="wordmark" href={url('/')} data-dbg="entete__marque" aria-label="Dan Phu — accueil">
          <img src={url('/img/logo-danphu.png')} alt="Dan Phu" class="wordmark-logo" width="657" height="96" />
        </a>
      )
    }
    <nav aria-label="Navigation principale" data-dbg="entete__nav">
      {
        nav.map((item) => (
          <a
            href={url(item.href)}
            aria-current={current === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

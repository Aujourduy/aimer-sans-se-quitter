---
import { url } from '../lib/url';

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  featured?: boolean;
  verified?: boolean;
}

const { title, excerpt, slug, featured = false, verified = false } = Astro.props;
---

<article class={`text-card ${featured ? 'text-card--featured' : ''}`} data-dbg={`texte-carte__${slug}`}>
  {
    import.meta.env.DEV && (
      <span
        class={`dev-verif ${verified ? 'dev-verif--ok' : 'dev-verif--todo'}`}
        title={verified ? 'Relu et validé par Duy' : 'À relire / valider'}
      >
        {verified ? '✓ validé' : '◯ à valider'}
      </span>
    )
  }
  <a class="text-card-link" href={url(`/textes/${slug}`)}>
    <h3 class="text-card-title">{title}</h3>
    <p class="text-card-excerpt">{excerpt}</p>
    <span class="text-card-more">Lire</span>
  </a>
</article>

<style>
  /* Repère de relecture — rendu uniquement en développement (import.meta.env.DEV). */
  .text-card {
    position: relative;
  }
  .dev-verif {
    position: absolute;
    top: 0.4rem;
    right: 0.4rem;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.1rem 0.45rem;
    border-radius: 0.6rem;
    line-height: 1.35;
    z-index: 2;
  }
  .dev-verif--ok {
    background: #1f7a3d;
    color: #fff;
  }
  .dev-verif--todo {
    background: #e7e0d4;
    color: #6b6256;
    border: 1px solid #cbbfa8;
  }
</style>

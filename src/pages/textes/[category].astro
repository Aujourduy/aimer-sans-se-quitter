---
import Base from '../../layouts/Base.astro';
import TextCard from '../../components/TextCard.astro';
import { getCollection } from 'astro:content';
import {
  CATEGORY_LABELS,
  CATEGORY_SUBTITLES,
  CATEGORY_INTROS,
  CATEGORY_ORDER,
} from '../../lib/categories';

// Une page par catégorie (cinq au total), générée depuis la collection.
// Destination des titres de catégorie de la page Textes (§5.2bis du brief).
export async function getStaticPaths() {
  const all = await getCollection('textes', ({ data }) => !data.draft || import.meta.env.DEV);
  return CATEGORY_ORDER.map((cat) => ({
    params: { category: cat },
    props: {
      category: cat,
      // Les textes d'entrée (entry) restent mis en avant sur la page sommaire,
      // mais apparaissent aussi dans la liste de leur catégorie (ils en font
      // partie) — d'où l'absence de filtre sur `entry` ici.
      items: all
        .filter((t) => t.data.category === cat)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { category, items } = Astro.props;
const label = CATEGORY_LABELS[category];
const subtitle = CATEGORY_SUBTITLES[category];
const intro = CATEGORY_INTROS[category];
---

<Base title={label} description={`Écrits de la thématique « ${label} ».`}>
  <section class="lecture" data-dbg={`theme__${category}`}>
    <h1 data-dbg="theme__titre">{label}</h1>
    <p class="lede">{subtitle}</p>
    <div class="theme-intro" data-dbg="theme__intro">
      {intro.map((p) => <p>{p}</p>)}
    </div>
    {
      items.length > 0 ? (
        <>
          <hr class="separateur" />
          <div class="text-list">
            {items.map((t) => (
              <TextCard
                title={t.data.title}
                excerpt={t.data.excerpt}
                slug={t.id}
                verified={t.data.verifieParDuy}
                draft={t.data.draft ?? false}
              />
            ))}
          </div>
        </>
      ) : (
        <p class="lede">Aucun écrit publié dans cette thématique pour le moment.</p>
      )
    }
  </section>
</Base>

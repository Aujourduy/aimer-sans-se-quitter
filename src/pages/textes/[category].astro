---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/url';
import { romain } from '../../lib/romain';
import {
  CATEGORY_LABELS,
  CATEGORY_SUBTITLES,
  CATEGORY_INTROS,
  CATEGORY_ORDER,
} from '../../lib/categories';

// Une page par catégorie (cinq au total). Numéro de partie I–V selon l'anneau.
export async function getStaticPaths() {
  const all = await getCollection('textes', ({ data }) => !data.draft || import.meta.env.DEV);
  return CATEGORY_ORDER.map((cat, i) => ({
    params: { category: cat },
    props: {
      category: cat,
      num: romain(i + 1).toUpperCase(),
      items: all
        .filter((t) => t.data.category === cat)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { category, num, items } = Astro.props;
const label = CATEGORY_LABELS[category];
const subtitle = CATEGORY_SUBTITLES[category];
const intro = CATEGORY_INTROS[category];
// La dernière ligne de l'intro est la question récurrente (en italique bleu).
const introBody = intro.slice(0, -1);
const question = intro[intro.length - 1];
---

<Base title={label} description={`Écrits de la thématique « ${label} ».`}>
  <div class="page" data-dbg={`theme__${category}`}>
    <div class="part-opening" data-dbg="theme__ouverture">
      <span class="part-num">{num}</span>
      <h1 data-dbg="theme__titre">{label}</h1>
    </div>

    <div class="intro" data-dbg="theme__intro">
      {subtitle && <p>{subtitle}</p>}
      {introBody.map((p) => <p>{p}</p>)}
      {question && <p class="question">{question}</p>}
    </div>

    {
      items.length > 0 ? (
        <div class="liste" data-dbg="theme__liste">
          {items.map((t) => (
            <a class="rangee" href={url(`/textes/${t.id}`)}>
              <span class="rangee-titre">{t.data.title}</span>
              <span class="rangee-excerpt">{t.data.excerpt}</span>
              <span class="lire">Lire</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="intro">Aucun écrit publié dans cette thématique pour le moment.</p>
      )
    }
  </div>
</Base>

{/* Titres des textes lus en sépia (Tâche 2) — pages de thème. */}
<script>
  import {
    slugDepuisPathname,
    lireLus,
  } from '../../scripts/lecture-memoire.js';

  document.addEventListener('DOMContentLoaded', () => {
    const lus = lireLus();
    if (!lus.length) return;
    document.querySelectorAll('.rangee:not(.theme)').forEach((rangee) => {
      const href = rangee.getAttribute('href');
      if (!href) return;
      const slug = slugDepuisPathname(new URL(href, window.location.href).pathname);
      if (lus.includes(slug)) {
        rangee.classList.add('is-lu');
        const lbl = rangee.querySelector('.lire');
        if (lbl) lbl.textContent = 'Relire';
      }
    });
  });
</script>

<style>
  .page { --colonne: 40rem; }
</style>

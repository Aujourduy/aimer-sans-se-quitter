---
import Base from '../../layouts/Base.astro';
import TextCard from '../../components/TextCard.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/url';
import {
  CATEGORY_LABELS,
  CATEGORY_DESCRIPTIONS,
  CATEGORY_ORDER,
  ENTRY_ROLE_ORDER,
} from '../../lib/categories';

const all = await getCollection('textes', ({ data }) => !data.draft);

// Tableau de bord de relecture : tous les textes (brouillons compris), dev only.
const allForReview = import.meta.env.DEV ? await getCollection('textes') : [];
const reviewBoard = CATEGORY_ORDER.map((cat) => ({
  label: CATEGORY_LABELS[cat],
  items: allForReview
    .filter((t) => t.data.category === cat)
    .sort((a, b) => a.data.order - b.data.order),
}));
const reviewTotal = allForReview.length;
const reviewDone = allForReview.filter((t) => t.data.verifieParDuy).length;

// Trois textes d'entrée, triés par rôle (reconnaissance, déplacement, mécanisme).
const entries = all
  .filter((t) => t.data.entry)
  .sort(
    (a, b) =>
      ENTRY_ROLE_ORDER.indexOf(a.data.entryRole ?? 'reconnaissance') -
      ENTRY_ROLE_ORDER.indexOf(b.data.entryRole ?? 'reconnaissance')
  );

// Sommaire : une carte par catégorie (nom + description + lien vers le thème).
// Pas de déroulé des textes ici, pas d'accordéon.
const categories = CATEGORY_ORDER.map((cat) => ({
  category: cat,
  label: CATEGORY_LABELS[cat],
  description: CATEGORY_DESCRIPTIONS[cat],
}));
---

<Base
  title="Écrits"
  description="Fragments sur l’amour, le désir, la peur, le corps et les endroits où l’on se perd."
>
  <section class="lecture" data-dbg="textes__entete">
    <h1 data-dbg="textes__titre">Écrits</h1>
    <p class="lede">
      Fragments sur l’amour, le désir, la peur, le corps et les endroits où
      l’on se perd.
    </p>
    <div class="textes-intro" data-dbg="textes__intro">
      <p>Ces textes sont nés d’une même question :</p>
      <p>Comment rester avec soi-même lorsque l’on aime quelqu’un ?</p>
      <p>Voici quelques traces de cette recherche.</p>
      <p>Des textes écrits au fil des années à une amie inconnue.</p>
      <p>Vous pouvez commencer n’importe où.</p>
    </div>
  </section>

  {
    import.meta.env.DEV && (
      <section class="lecture dev-review" data-dbg="textes__relecture-dev">
        <h2>
          Relecture — {reviewDone}/{reviewTotal} validés
          <span class="dev-review-note"> (visible en développement uniquement)</span>
        </h2>
        {reviewBoard.map((grp) => (
          <details class="dev-review-cat">
            <summary>
              {grp.label} —{' '}
              {grp.items.filter((i) => i.data.verifieParDuy).length}/
              {grp.items.length}
            </summary>
            <ul class="dev-review-list">
              {grp.items.map((t) => (
                <li class={t.data.verifieParDuy ? 'is-ok' : 'is-todo'}>
                  <span class="mark">{t.data.verifieParDuy ? '✓' : '◯'}</span>
                  <a href={url(`/textes/${t.id}`)}>{t.data.title}</a>
                  {t.data.draft && <em class="draft">brouillon</em>}
                </li>
              ))}
            </ul>
          </details>
        ))}
      </section>
    )
  }

  {
    entries.length > 0 && (
      <section class="lecture" data-dbg="textes__entrees">
        <h2>Trois écrits pour entrer</h2>
        <div class="text-list">
          {entries.map((t) => (
            <TextCard
              title={t.data.title}
              excerpt={t.data.excerpt}
              slug={t.id}
              featured={true}
              verified={t.data.verifieParDuy}
              draft={t.data.draft ?? false}
            />
          ))}
        </div>
      </section>
    )
  }

  <section class="lecture" data-dbg="textes__sommaire">
    {
      categories.map((cat) => (
        <article class="cat-card" data-dbg={`textes__cat-${cat.category}`}>
          <h2 class="cat-card-title">{cat.label}</h2>
          <p class="cat-card-desc">{cat.description}</p>
          <a class="cat-card-link" href={url(`/textes/${cat.category}`)}>
            Explorer
          </a>
        </article>
      ))
    }
  </section>
</Base>

<style>
  /* Tableau de bord de relecture — rendu uniquement en développement. */
  .dev-review {
    border: 1px dashed #cbbfa8;
    border-radius: 0.6rem;
    padding: 1rem 1.25rem;
    background: #faf7f1;
  }
  .dev-review-note {
    font-size: 0.8rem;
    font-weight: 400;
    color: #8a8073;
  }
  .dev-review-cat {
    margin: 0.4rem 0;
  }
  .dev-review-cat summary {
    cursor: pointer;
    font-weight: 600;
  }
  .dev-review-list {
    list-style: none;
    padding-left: 0.5rem;
    margin: 0.4rem 0 0.8rem;
  }
  .dev-review-list li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.1rem 0;
  }
  .dev-review-list .mark {
    width: 1.2em;
    text-align: center;
  }
  .dev-review-list .is-ok .mark {
    color: #1f7a3d;
  }
  .dev-review-list .is-todo {
    color: #6b6256;
  }
  .dev-review-list .draft {
    font-size: 0.75rem;
    color: #b08900;
  }
</style>

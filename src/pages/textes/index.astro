---
import Base from '../../layouts/Base.astro';
import TextCard from '../../components/TextCard.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/url';
import {
  CATEGORY_LABELS,
  CATEGORY_DESCRIPTIONS,
  CATEGORY_ORDER,
  ENTRY_ROLE_ORDER,
  DESIR_INTIMITE_INTRO,
} from '../../lib/categories';

const all = await getCollection('textes', ({ data }) => !data.draft);

// Trois textes d'entrée, triés par rôle (reconnaissance, déplacement, mécanisme).
const entries = all
  .filter((t) => t.data.entry)
  .sort(
    (a, b) =>
      ENTRY_ROLE_ORDER.indexOf(a.data.entryRole ?? 'reconnaissance') -
      ENTRY_ROLE_ORDER.indexOf(b.data.entryRole ?? 'reconnaissance')
  );

// Sommaire : une carte par catégorie (nom + description + lien vers le thème).
// Pas de déroulé des textes ici, pas d'accordéon.
const categories = CATEGORY_ORDER.map((cat) => ({
  category: cat,
  label: CATEGORY_LABELS[cat],
  description: CATEGORY_DESCRIPTIONS[cat],
}));
---

<Base
  title="Textes"
  description="Fragments sur l’amour, le désir, la peur, le corps et les endroits où l’on se perd."
>
  <section class="lecture" data-dbg="textes__entete">
    <h1 data-dbg="textes__titre">Textes</h1>
    <p class="lede">
      Fragments sur l’amour, le désir, la peur, le corps et les endroits où
      l’on se perd.
    </p>
  </section>

  {
    entries.length > 0 && (
      <section class="lecture" data-dbg="textes__entrees">
        <h2>Trois textes pour entrer</h2>
        <div class="text-list">
          {entries.map((t) => (
            <TextCard
              title={t.data.title}
              excerpt={t.data.excerpt}
              slug={t.id}
              featured={true}
            />
          ))}
        </div>
      </section>
    )
  }

  <section class="lecture" data-dbg="textes__sommaire">
    {
      categories.map((cat) => (
        <article class="cat-card" data-dbg={`textes__cat-${cat.category}`}>
          <h2 class="cat-card-title">{cat.label}</h2>
          <p class="cat-card-desc">{cat.description}</p>
          {cat.category === 'desir-intimite' && (
            <p class="intime-intro">{DESIR_INTIMITE_INTRO}</p>
          )}
          <a class="cat-card-link" href={url(`/textes/${cat.category}`)}>
            Voir les textes
          </a>
        </article>
      ))
    }
  </section>
</Base>

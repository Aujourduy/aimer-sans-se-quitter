---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/url';
import {
  CATEGORY_LABELS,
  CATEGORY_DESCRIPTIONS,
  CATEGORY_ORDER,
  ENTRY_ROLE_ORDER,
} from '../../lib/categories';
import { romain } from '../../lib/romain';

// Brouillons visibles en dev ou dans le build « de relecture » (PWA de dev,
// INCLUDE_DRAFTS=true) ; masqués en prod (danphu.com inchangé).
const showDrafts = import.meta.env.DEV || process.env.INCLUDE_DRAFTS === 'true';
const all = await getCollection('textes', ({ data }) => !data.draft || showDrafts);

// Tableau de bord de relecture : tous les textes (brouillons compris).
const allForReview = showDrafts ? await getCollection('textes') : [];
const reviewBoard = CATEGORY_ORDER.map((cat) => ({
  label: CATEGORY_LABELS[cat],
  items: allForReview
    .filter((t) => t.data.category === cat)
    .sort((a, b) => a.data.order - b.data.order),
}));
const reviewTotal = allForReview.length;
const reviewDone = allForReview.filter((t) => t.data.verifieParDuy).length;

// Trois textes d'entrée, triés par rôle (reconnaissance, déplacement, mécanisme).
const entries = all
  .filter((t) => t.data.entry)
  .sort(
    (a, b) =>
      ENTRY_ROLE_ORDER.indexOf(a.data.entryRole ?? 'reconnaissance') -
      ENTRY_ROLE_ORDER.indexOf(b.data.entryRole ?? 'reconnaissance')
  );

// Sommaire : une rangée par thème, numérotée I–V dans l'ordre de l'anneau.
const themes = CATEGORY_ORDER.map((cat, i) => ({
  category: cat,
  num: romain(i + 1).toUpperCase(), // sommaire : majuscules romaines (I–V)
  label: CATEGORY_LABELS[cat],
  description: CATEGORY_DESCRIPTIONS[cat],
}));
---

<Base
  title="Écrits"
  description="Fragments sur l’amour, le désir, la peur, le corps et les endroits où l’on se perd."
>
  <div class="page" data-dbg="textes">
    <h1 data-dbg="textes__titre">Écrits</h1>
    <div class="intro" data-dbg="textes__intro">
      <p>
        Une même question, posée au fil des années : comment rester avec
        soi-même lorsque l’on aime quelqu’un ?
      </p>
      <p>Des traces de cette recherche, écrites à une amie inconnue.</p>
      <p>Vous pouvez commencer n’importe où.</p>
    </div>

    {/* « Reprendre la lecture » (Tâche 3) : conteneur vide, masqué côté serveur.
        Le script le remplit et le révèle si un dernier texte existe. */}
    <p class="reprendre" data-dbg="textes__reprendre" hidden></p>

    {
      showDrafts && (
        <section class="dev-review" data-dbg="textes__relecture-dev">
          <h2 class="eyebrow">
            Relecture — {reviewDone}/{reviewTotal} validés (dev)
          </h2>
          {reviewBoard.map((grp) => (
            <details class="dev-review-cat">
              <summary>
                {grp.label} —{' '}
                {grp.items.filter((i) => i.data.verifieParDuy).length}/
                {grp.items.length}
              </summary>
              <ul class="dev-review-list">
                {grp.items.map((t) => (
                  <li class={t.data.verifieParDuy ? 'is-ok' : 'is-todo'}>
                    <span class="mark">{t.data.verifieParDuy ? '✓' : '◯'}</span>
                    <a href={url(`/textes/${t.id}`)}>{t.data.title}</a>
                    {t.data.draft && <em class="draft">brouillon</em>}
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </section>
      )
    }

    {
      entries.length > 0 && (
        <>
          <h2 class="eyebrow" data-dbg="textes__entrees-titre">
            Trois écrits pour entrer
          </h2>
          {entries.map((t) => (
            <a class="rangee" href={url(`/textes/${t.id}`)}>
              <span class="rangee-titre">{t.data.title}</span>
              <span class="rangee-excerpt">{t.data.excerpt}</span>
              <span class="lire">Lire</span>
            </a>
          ))}
        </>
      )
    }

    <h2 class="eyebrow" data-dbg="textes__sommaire-titre">Le sommaire</h2>
    {
      themes.map((t) => (
        <a
          class="rangee theme"
          href={url(`/textes/${t.category}`)}
          data-dbg={`textes__theme-${t.category}`}
        >
          <span class="theme-num">{t.num}</span>
          <span>
            <span class="theme-titre">{t.label}</span>
            <span class="theme-desc">{t.description}</span>
            <span class="lire">Explorer</span>
          </span>
        </a>
      ))
    }
  </div>
</Base>

{/* Titres lus en sépia (Tâche 2) + « Reprendre » (Tâche 3). */}
<script>
  import {
    slugDepuisPathname,
    lireLus,
    lireDernier,
  } from '../../scripts/lecture-memoire.js';

  document.addEventListener('DOMContentLoaded', () => {
    // Tâche 2 — titres des textes lus en sépia. Les rangées de thème (.theme)
    // ne sont jamais marquées : on cible uniquement les rangées de texte.
    const lus = lireLus();
    if (lus.length) {
      document.querySelectorAll('.rangee:not(.theme)').forEach((rangee) => {
        const href = rangee.getAttribute('href');
        if (!href) return;
        const slug = slugDepuisPathname(new URL(href, window.location.href).pathname);
        if (lus.includes(slug)) {
          rangee.classList.add('is-lu');
          const lbl = rangee.querySelector('.lire');
          if (lbl) lbl.textContent = 'Relire';
        }
      });
    }

    // Tâche 3 — « Reprendre — ‹titre› » si un dernier texte existe.
    const conteneur = document.querySelector('.reprendre');
    const dernier = lireDernier();
    if (conteneur && dernier && dernier.url && dernier.titre) {
      const lien = document.createElement('a');
      lien.href = dernier.url;
      lien.textContent = dernier.titre;
      conteneur.append('Reprendre — ', lien);
      conteneur.hidden = false;
    }
  });
</script>

<style>
  /* Index / sommaire : colonne de revue. */
  .page { --colonne: 40rem; }

  /* Tableau de bord de relecture — rendu uniquement en développement. */
  .dev-review {
    border: 1px dashed #cbbfa8;
    border-radius: 0.6rem;
    padding: 1rem 1.25rem;
    background: #faf7f1;
    margin-top: var(--silence-moyen);
  }
  .dev-review .eyebrow { margin: 0 0 0.4rem; }
  .dev-review-cat { margin: 0.4rem 0; }
  .dev-review-cat summary { cursor: pointer; font-weight: 600; }
  .dev-review-list { list-style: none; padding-left: 0.5rem; margin: 0.4rem 0 0.8rem; }
  .dev-review-list li { display: flex; align-items: baseline; gap: 0.5rem; padding: 0.1rem 0; }
  .dev-review-list .mark { width: 1.2em; text-align: center; }
  .dev-review-list .is-ok .mark { color: #1f7a3d; }
  .dev-review-list .is-todo { color: #6b6256; }
  .dev-review-list .draft { font-size: 0.75rem; color: #b08900; }
</style>

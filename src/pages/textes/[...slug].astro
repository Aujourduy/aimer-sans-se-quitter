---
import Base from '../../layouts/Base.astro';
import Pont from '../../components/Pont.astro';
import Fleuron from '../../components/Fleuron.astro';
import NavTexte from '../../components/NavTexte.astro';
import { getCollection, render } from 'astro:content';
import { CATEGORY_LABELS } from '../../lib/categories';

// Folio de page intérieure de livre : le rang du fragment dans sa série, en
// chiffres romains bas-de-casse (brief v2 §6). Discret, jamais cliquable.
function romain(n: number): string {
  const t: [number, string][] = [
    [1000, 'm'], [900, 'cm'], [500, 'd'], [400, 'cd'],
    [100, 'c'], [90, 'xc'], [50, 'l'], [40, 'xl'],
    [10, 'x'], [9, 'ix'], [5, 'v'], [4, 'iv'], [1, 'i'],
  ];
  let r = '';
  for (const [v, s] of t) while (n >= v) { r += s; n -= v; }
  return r;
}

export async function getStaticPaths() {
  // En dev, on génère aussi les pages des brouillons pour pouvoir les relire ;
  // en production, les brouillons restent exclus.
  const textes = await getCollection(
    'textes',
    ({ data }) => !data.draft || import.meta.env.DEV
  );
  return textes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const verified = entry.data.verifieParDuy;
const isDraft = entry.data.draft ?? false;
const categorie = CATEGORY_LABELS[entry.data.category];
const folio = romain(entry.data.order); // rang dans la série, en romain bas-de-casse
---

<Base title={entry.data.title} description={entry.data.excerpt}>
  <article class="lecture" data-dbg="texte">
    {
      import.meta.env.DEV && (
        <div class="dev-verif-group" data-dbg="texte__relecture-dev">
          <span
            class={`dev-verif ${verified ? 'dev-verif--ok' : 'dev-verif--todo'}`}
            title={verified ? 'Relu et validé par Duy' : 'À relire / valider'}
          >
            {verified ? '✓ validé' : '◯ à valider'}
          </span>
          <span
            class={`dev-draft ${isDraft ? 'dev-draft--on' : 'dev-draft--off'}`}
            title={isDraft ? 'Brouillon (masqué en production)' : 'Publié'}
          >
            {isDraft ? 'brouillon' : 'publié'}
          </span>
        </div>
      )
    }
    {/* Titre courant : marque de page intérieure de livre, à la limite du
        perceptible (Inter sépia, jamais bleu, jamais cliquable). Brief v2 §6. */}
    <p class="titre-courant" data-dbg="texte__titre-courant">{categorie}</p>
    <h1 class="article-title" data-dbg="texte__titre">{entry.data.title}</h1>
    <div class="prose" data-dbg="texte__corps">
      <Content />
    </div>
    <Fleuron />
    <Pont />
    <NavTexte
      slug={entry.id}
      category={entry.data.category}
      order={entry.data.order}
    />
    {/* Folio : rang du fragment dans sa série, romain bas-de-casse, discret. */}
    <p class="folio" data-dbg="texte__folio">{folio}</p>
  </article>
</Base>

<style>
  /* Repères de relecture — rendus uniquement en développement
     (import.meta.env.DEV), jamais en production. */
  .dev-verif-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .dev-verif,
  .dev-draft {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.1rem 0.45rem;
    border-radius: 0.6rem;
    line-height: 1.35;
  }
  .dev-verif--ok {
    background: #1f7a3d;
    color: #fff;
  }
  .dev-verif--todo {
    background: #e7e0d4;
    color: #6b6256;
    border: 1px solid #cbbfa8;
  }
  .dev-draft--on {
    background: #b08900;
    color: #fff;
  }
  .dev-draft--off {
    background: #e7e0d4;
    color: #6b6256;
    border: 1px solid #cbbfa8;
  }
</style>

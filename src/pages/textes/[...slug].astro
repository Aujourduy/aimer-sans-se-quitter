---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { CATEGORY_LABELS, CATEGORY_ORDER } from '../../lib/categories';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  // En dev (ou build « de relecture » INCLUDE_DRAFTS=true, PWA de dev), on génère
  // aussi les pages des brouillons ; en production, ils restent exclus.
  const showDrafts = import.meta.env.DEV || process.env.INCLUDE_DRAFTS === 'true';
  const textes = await getCollection(
    'textes',
    ({ data }) => !data.draft || showDrafts
  );
  return textes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const verified = entry.data.verifieParDuy;
const isDraft = entry.data.draft ?? false;
const categorie = CATEGORY_LABELS[entry.data.category];
// Repères de relecture : dev ou build « de relecture » (PWA de dev).
const showDrafts = import.meta.env.DEV || process.env.INCLUDE_DRAFTS === 'true';

// « Continuer par un autre texte » : le texte publié suivant dans la catégorie,
// sinon le premier texte de la catégorie suivante (anneau). Calcul à la
// construction — aucun JavaScript côté client.
const published = await getCollection('textes', ({ data }) => !data.draft);
const ring = CATEGORY_ORDER.filter((cat) =>
  published.some((t) => t.data.category === cat)
);
const inCat = published
  .filter((t) => t.data.category === entry.data.category)
  .sort((a, b) => a.data.order - b.data.order);
const idx = inCat.findIndex((t) => t.id === entry.id);

let suivant: string | null = null;
if (idx !== -1 && idx < inCat.length - 1) {
  suivant = inCat[idx + 1].id;
} else if (ring.length > 1) {
  const pos = ring.indexOf(entry.data.category);
  const nextCat = ring[(pos + 1) % ring.length];
  const firstOfNext = published
    .filter((t) => t.data.category === nextCat)
    .sort((a, b) => a.data.order - b.data.order)[0];
  if (firstOfNext) suivant = firstOfNext.id;
}
---

<Base title={entry.data.title} description={entry.data.excerpt}>
  <article class="lecture" data-dbg="texte">
    {
      showDrafts && (
        <div class="dev-verif-group" data-dbg="texte__relecture-dev">
          <span
            class={`dev-verif ${verified ? 'dev-verif--ok' : 'dev-verif--todo'}`}
            title={verified ? 'Relu et validé par Duy' : 'À relire / valider'}
          >
            {verified ? '✓ validé' : '◯ à valider'}
          </span>
          <span
            class={`dev-draft ${isDraft ? 'dev-draft--on' : 'dev-draft--off'}`}
            title={isDraft ? 'Brouillon (masqué en production)' : 'Publié'}
          >
            {isDraft ? 'brouillon' : 'publié'}
          </span>
        </div>
      )
    }
    {/* Titre courant : thème, petites capitales sépia. */}
    <p class="titre-courant" data-dbg="texte__titre-courant">{categorie}</p>
    <h1 class="article-title" data-dbg="texte__titre">{entry.data.title}</h1>

    {/* Le texte coule en paragraphes égaux. Aucune mise en forme (ni lettrine,
        ni exergue, ni fleuron) — le sink (.prose margin-top) suffit comme seuil. */}
    <div class="prose" data-dbg="texte__corps">
      <Content />
    </div>

    {/* Fin : deux liens de poids égal, en EB Garamond, soulignés d'un filet bleu
        fin. Pas de pont, pas de bouton, pas de folio, aucun JavaScript. */}
    <nav class="fin" data-dbg="texte__fin" aria-label="Pour continuer">
      {
        suivant && (
          <a href={url(`/textes/${suivant}`)}>Continuer par un autre texte</a>
        )
      }
      <span class="ou">ou</span>
      <a href={url('/accompagnement')}>Découvrir l’accompagnement</a>
    </nav>
  </article>
</Base>

{/* Mémoire de lecture (Tâche 1) : enregistre le dernier texte ouvert au
    chargement, et marque le texte « lu » quand la fin (.fin) entre dans le
    viewport. Aucun affichage, aucun bouton. Tout est passif et robuste. */}
<script>
  import {
    slugDepuisPathname,
    marquerLu,
    enregistrerDernier,
  } from '../../scripts/lecture-memoire.js';

  document.addEventListener('DOMContentLoaded', () => {
    const slug = slugDepuisPathname(window.location.pathname);
    if (!slug) return;

    // 1. Dernier texte ouvert — écrit immédiatement (sert à « Reprendre »).
    const h1 = document.querySelector('.article-title');
    const titre = h1 ? h1.textContent.trim() : document.title;
    enregistrerDernier({ slug, titre, url: window.location.href });

    // 2. Texte lu — quand la fin entre dans le viewport.
    const fin = document.querySelector('.fin');
    if (fin && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            marquerLu(slug);
            observer.disconnect();
            break;
          }
        }
      });
      observer.observe(fin);
    }
  });
</script>

<style>
  /* Repères de relecture — rendus uniquement en développement, jamais en prod. */
  .dev-verif-group { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.25rem; }
  .dev-verif, .dev-draft { font-size: 0.7rem; font-weight: 600; padding: 0.1rem 0.45rem; border-radius: 0.6rem; line-height: 1.35; }
  .dev-verif--ok { background: #1f7a3d; color: #fff; }
  .dev-verif--todo { background: #e7e0d4; color: #6b6256; border: 1px solid #cbbfa8; }
  .dev-draft--on { background: #b08900; color: #fff; }
  .dev-draft--off { background: #e7e0d4; color: #6b6256; border: 1px solid #cbbfa8; }
</style>

---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait.jpg';

// Lien de réservation TidyCal. (Les questions posées au moment de la
// réservation se configurent dans TidyCal — voir le README, section
// « Réservation ».)
const RESERVATION_URL = 'https://tidycal.com/duy-dang/conversation-exploratoire';
---

<Base
  title="Conversation exploratoire"
  description="Une conversation pour sentir, ensemble, si ce travail est juste pour vous."
>
  <article class="lecture" data-dbg="conversation">
    <div class="portrait portrait--petit" data-dbg="conversation__portrait">
      <Image
        src={portrait}
        alt="Portrait de l’auteur, au bord d’un plan d’eau en automne."
        widths={[220, 440]}
        sizes="220px"
      />
    </div>

    <h1 class="article-title" data-dbg="conversation__titre">La conversation exploratoire</h1>

    <div class="prose" data-dbg="conversation__corps">
      <p>
        Nous prendrons un temps pour regarder ce qui vous amène aujourd’hui.
      </p>
      <p>Ce qui se répète.</p>
      <p>Ce qui vous trouble.</p>
      <p>
        L’endroit où vous sentez qu’il y a quelque chose à voir mais où vous ne
        voyez pas encore clairement.
      </p>
      <p>Nous verrons également si ce cadre est juste pour vous.</p>
      <p>Et si ce moment est le bon.</p>

      <p class="note">
        Quelques questions vous seront posées au moment de votre demande.
      </p>
      <p class="note">
        Elles nous permettront d’arriver tous les deux préparés.
      </p>

      <div class="btn-group" data-dbg="conversation__cta">
        <Button href={RESERVATION_URL} variant="principal" external={true}
          >Demander une conversation exploratoire</Button
        >
      </div>
    </div>
  </article>
</Base>

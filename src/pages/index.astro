---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';
---

<Base
  description="Quand votre manière d’aimer vous éloigne de vous-même. Un accompagnement relationnel privé, qui part des textes."
>
  <section class="page seuil" data-dbg="accueil__seuil">
    <h1 data-dbg="accueil__titre">Aimer sans se quitter</h1>
    <p class="sous-titre" data-dbg="accueil__sous-titre">
      Quand votre manière d’aimer vous éloigne de vous-même.
    </p>
    {/* Signature d'auteur discrète, en pied de faux-titre. */}
    <p class="signature" data-dbg="accueil__signature">— Dan Phu</p>

    {/* Fleuron d'ouverture : le blanc autour du titre devient composé (CDC §2). */}
    <p class="fleuron fleuron--ouverture" role="separator" aria-hidden="true">✻ ✻ ✻</p>

    <p class="regard" data-dbg="accueil__regard">
      La rupture n’est pas le sujet. Elle est un révélateur : elle montre,
      soudain et sans ménagement, l’endroit exact où vous cessez de vous
      appartenir pour garder le lien.
    </p>

    <div class="portes" data-dbg="accueil__porte">
      <a class="porte" href={url('/textes')}>Entrer par un texte</a>
    </div>
  </section>
</Base>

<style>
  /* Accueil — un seuil resserré (colonne plus étroite) et beaucoup de blanc
     composé. Le logo DAN PHU est dans l'en-tête (comme les pages intérieures),
     le faux-titre annonce l'œuvre juste en dessous. */
  .seuil {
    --colonne: 36rem;
    padding-top: var(--silence-seuil);
  }
  @media (max-width: 640px) {
    .seuil { padding-top: var(--silence-long); }
  }
  .seuil :global(h1) {
    font-size: clamp(2.1rem, 6.5vw, 3.3rem);
    line-height: 1.08;
    text-wrap: balance;
  }
  .sous-titre {
    margin: var(--silence-court) 0 0;
    color: var(--sepia);
    font-size: clamp(1.1rem, 3.4vw, 1.3rem);
    line-height: 1.4;
    max-width: 30ch;
  }
  /* L'unique paragraphe — le premier « il voit ». */
  .regard { margin: calc(var(--b) * 9) 0 0; line-height: 1.6; }
  @media (max-width: 640px) {
    .regard { margin-top: var(--silence-moyen); }
  }
</style>

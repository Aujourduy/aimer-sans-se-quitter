---
import '../styles/fonts.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// import DebugMode from '../components/DebugMode.astro'; // masqué jusqu'à nouvel ordre

interface Props {
  title?: string;
  description?: string;
  // Masque le wordmark de l'en-tête (accueil : le faux-titre porte la marque).
  wordmark?: boolean;
}

const {
  title = '',
  description = 'Accompagnement relationnel privé — aimer sans se quitter soi-même.',
  wordmark = true,
} = Astro.props;

// La balise <title> (et og:title / twitter:title) est volontairement fixée à
// « Dan Phu » sur toutes les pages, accueil comprise. La prop `title` reste
// acceptée (pour ne rien casser ailleurs) mais n'influe plus sur ces balises.
const metaTitle = 'Dan Phu';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metaTitle} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="any" />
    <link rel="icon" href={`${base}favicon-32.png`} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    {/* PWA : manifeste + couleur de thème (crème). Base-aware. */}
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="theme-color" content="#F4EFE6" />
    {/* Préchargement des 3 woff2 latin réellement utilisés : la fonte est prête
        dans la fenêtre de blocage de font-display: optional → pas de FOUT, et,
        avec le repli métrique, CLS = 0 (brief v2 §1). */}
    <link rel="preload" href={`${base}fonts/eb-garamond-latin-400-normal.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={`${base}fonts/eb-garamond-latin-400-italic.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={`${base}fonts/eb-garamond-latin-600-normal.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <script
      defer
      data-domain="danphu.com"
      src="https://plausible.aujourduy.fr/js/script.hash.outbound-links.js"
    ></script>
  </head>
  <body>
    <Header wordmark={wordmark} />
    <main>
      <slot />
    </main>
    <Footer />
    {/* Mode debug (bouton « $ ») masqué jusqu'à nouvel ordre — dé-commenter pour réactiver. */}
    {/* <DebugMode /> */}
    {/* PWA : enregistrement du service worker généré par Workbox. Base-aware,
        feature-detecté ; silencieux si indisponible. Le SW (autoUpdate) se met
        à jour seul, donc on recharge pas la page à la main. */}
    <script is:inline define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register(base + 'sw.js', { scope: base })
            .catch(() => {});
        });
      }
    </script>
  </body>
</html>

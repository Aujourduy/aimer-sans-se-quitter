---
import '../styles/fonts.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// import DebugMode from '../components/DebugMode.astro'; // masqué jusqu'à nouvel ordre

interface Props {
  title?: string;
  description?: string;
  // Masque le wordmark de l'en-tête (accueil : le faux-titre porte la marque).
  wordmark?: boolean;
}

const {
  title = '',
  description = 'Accompagnement relationnel privé — aimer sans se quitter soi-même.',
  wordmark = true,
} = Astro.props;

const fullTitle = title
  ? `${title} — Aimer sans se quitter`
  : 'Aimer sans se quitter';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    {/* Préchargement des 3 woff2 latin réellement utilisés : la fonte est prête
        dans la fenêtre de blocage de font-display: optional → pas de FOUT, et,
        avec le repli métrique, CLS = 0 (brief v2 §1). */}
    <link rel="preload" href={`${base}fonts/eb-garamond-latin-400-normal.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={`${base}fonts/eb-garamond-latin-400-italic.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={`${base}fonts/eb-garamond-latin-600-normal.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <script
      defer
      data-domain="danphu.com"
      src="https://plausible.aujourduy.fr/js/script.hash.outbound-links.js"
    ></script>
  </head>
  <body>
    <Header wordmark={wordmark} />
    <main>
      <slot />
    </main>
    <Footer />
    {/* Mode debug (bouton « $ ») masqué jusqu'à nouvel ordre — dé-commenter pour réactiver. */}
    {/* <DebugMode /> */}
  </body>
</html>
